<?php
if (!defined('_CMBOARD_')) exit; // 개별 페이지 접근 불가

function get_current_filename() {
    // 1. 현재 접속한 웹 주소의 '경로'.
    $urlPath = $_SERVER['PHP_SELF'];

    // 2. 경로가 없으면  빈 값.
    if (empty($urlPath)) {
        return '';
    }

    // 3. 'basename()' 파일 이름(확장자 포함)만!
    // 예: /board/write.php 에서 write.php
    $filenameWithExt = basename($urlPath);

    // 4. 'pathinfo()' 이름에서 확장자 (.php)를 빼내고,
    // 순수한 파일 이름만.
    $filenameWithoutExt = pathinfo($filenameWithExt, PATHINFO_FILENAME);

    // 5. 순수한 파일 이름(예: write) 출력
    return $filenameWithoutExt;
}


function get_board_url($fileName, $board, $board_id='') {
	
	if (empty($board) || empty($fileName)) {
		$href = CM_URL;
		return $href;
	}
	
	if(isset($board)){
		$href = CM_BOARD_URL."/".$fileName.".php?board=".$board;
	}
	
	if(isset($board_id) && $board_id !== ""){
		$href .= "&id=".$board_id;
	}
	
	return $href;
}


function alert(string $message, ?string $redirect_url = null) // PHP 7.1 이상에서는 ?string 으로 null 허용 표시 가능
{
    // JavaScript 문자열 리터럴로 안전하게 만들기 위해 JSON 인코딩 사용 (따옴표, 줄바꿈 등 문제 해결)
    $escaped_message = json_encode((string)$message);

    echo '<script>';
    echo 'alert(' . $escaped_message . ');'; // alert 창 띄우기

    // 이동할 URL이 있는지 확인
    if (!empty($redirect_url)) {
        // URL도 JavaScript 문자열 리터럴로 안전하게 인코딩
        $escaped_url = json_encode((string)$redirect_url);
        echo 'window.location.href = ' . $escaped_url . ';'; // 지정된 URL로 이동
    } else {
        echo 'history.back();'; // 이전 페이지로 돌아가기
    }

    echo '</script>';

    // 이 함수가 호출된 후에 더 이상 PHP 코드가 실행되지 않도록 종료
    // (페이지 이동은 클라이언트(브라우저) 자바스크립트가 처리하므로 서버는 할 일 끝)
    exit;
}


/**
 * Bootstrap 5 스타일의 오류 알림을 표시하고 false를 반환
 * @param string $message 표시할 오류 메시지
 * @return false
 */
function bt_alert($message) {
    $escapedMessage = htmlspecialchars((string)$message, ENT_QUOTES, 'UTF-8');
    echo <<<HTML
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <strong>오류:</strong> $escapedMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
    <script>
        setTimeout(() => {
            document.querySelector('.alert').remove();
        }, 5000);
    </script>
HTML;
    return false;
}










// 이 파일의 상단에는 데이터베이스 연결 정보가 담긴 _common.php 등이 포함되어 있어야 합니다.
// $pdo 변수에 PDO 객체가 초기화되어 있어야 합니다.
// 예: require_once './_common.php'; // _common.php 파일에 $pdo 연결 코드 포함
// $pdo = new PDO(...); // 또는 이렇게 직접 연결 코드를 추가

/**
 * 일반 데이터 삽입 처리 함수 (process_data_insert)
 * 어떤 테이블에든 데이터를 삽입할 때 사용할 수 있습니다.
 * 삽입할 컬럼과 값은 $data 배열에 담아서 넘겨주세요.
 * 전역 변수 $pdo 를 사용합니다.
 *
 * @param string $tableName 데이터를 삽입할 테이블 이름 (예: 'cm_board', 'users')
 * @param array $data 삽입할 데이터 (컬럼명 => 값 형태의 연관 배열)
 * @return int|false 성공 시 새로 삽입된 행의 ID (AUTO_INCREMENT), 실패 시 false 반환
 */
function process_data_insert(string $tableName, array $data)
{
    global $pdo; // <-- 여기서 전역 변수 $pdo 에 접근!

    if (empty($data)) {
        error_log("process_data_insert: 삽입할 데이터가 비어 있습니다.");
        return false;
    }

    $columns = array_keys($data);
    $placeholders = implode(', ', array_map(fn($col) => ":" . $col, $columns));
    $columnSql = implode(', ', array_map(fn($col) => "`" . str_replace("`", "``", $col) . "`", $columns));

    $sql = "INSERT INTO `" . str_replace("`", "``", $tableName) . "` ({$columnSql}) VALUES ({$placeholders})";

    try {
        $stmt = $pdo->prepare($sql); // 전역 $pdo 사용
        $stmt->execute($data);
        return $pdo->lastInsertId(); // 전역 $pdo 사용

    } catch (PDOException $e) {
        error_log("process_data_insert 오류 ({$tableName}): " . $e->getMessage());
        return false;
    }
}

/**
 * 파일 메타데이터 삽입 처리 함수 (process_file_insert)
 * 업로드된 파일의 정보(이름, 크기 등)를 데이터베이스 테이블에 기록할 때 사용합니다.
 * 실제 파일 업로드 및 이동은 이 함수를 호출하기 전에 완료되어야 합니다.
 * 전역 변수 $pdo 를 사용합니다.
 *
 * @param string $tableName 파일 정보를 삽입할 테이블 이름 (예: 'cm_board_file')
 * @param array $data 삽입할 파일 데이터 (컬럼명 => 값 형태의 연관 배열)
 * @return int|false 성공 시 새로 삽입된 행의 ID (AUTO_INCREMENT), 실패 시 false 반환
 */
function process_file_insert(string $tableName, array $data)
{
    global $pdo; // <-- 여기서 전역 변수 $pdo 에 접근!

    // 파일 관련 삽입임을 명시하는 것 외에는 일반 데이터 삽입과 동일하게 처리합니다.
    // 내부적으로 process_data_insert 를 호출하는 대신, 직접 process_data_insert 의 로직을 따릅니다.
    // 이렇게 하면 process_data_insert 도 global $pdo 를 사용하게 됩니다.
    // 만약 process_data_insert를 그대로 재활용하려면, 그 함수도 global $pdo를 사용하도록 변경하거나
    // 이 함수 내부에서 $pdo를 인자로 넘겨줘야 합니다.
    // 여기서는 요청에 따라 각 함수가 직접 global $pdo를 사용하도록 수정했습니다.

    if (empty($data)) {
        error_log("process_file_insert: 삽입할 데이터가 비어 있습니다.");
        return false;
    }

    $columns = array_keys($data);
    $placeholders = implode(', ', array_map(fn($col) => ":" . $col, $columns));
     $columnSql = implode(', ', array_map(fn($col) => "`" . str_replace("`", "``", $col) . "`", $columns));


    $sql = "INSERT INTO `" . str_replace("`", "``", $tableName) . "` ({$columnSql}) VALUES ({$placeholders})";

    try {
        $stmt = $pdo->prepare($sql); // 전역 $pdo 사용
        $stmt->execute($data);
        return $pdo->lastInsertId(); // 전역 $pdo 사용

    } catch (PDOException $e) {
        error_log("process_file_insert 오류 ({$tableName}): " . $e->getMessage());
        return false;
    }
}


/**
 * 데이터 업데이트 처리 함수 (process_data_update)
 * 어떤 테이블에든 데이터를 업데이트할 때 사용할 수 있습니다.
 * 업데이트할 컬럼과 값은 $data 배열에, 업데이트 조건은 $whereConditions 배열에 담아주세요.
 * 전역 변수 $pdo 를 사용합니다.
 *
 * @param string $tableName 데이터를 업데이트할 테이블 이름
 * @param array $data 업데이트할 데이터 (컬럼명 => 값 형태의 연관 배열)
 * @param array $whereConditions WHERE 절 조건 (컬럼명 => 값 형태의 연관 배열)
 * @return bool 성공 시 true, 실패 시 false 반환
 */
function process_data_update(string $tableName, array $data, array $whereConditions)
{
    global $pdo; // <-- 여기서 전역 변수 $pdo 에 접근!

    if (empty($data)) {
        error_log("process_data_update: 업데이트할 데이터가 비어 있습니다.");
        return false;
    }
    if (empty($whereConditions)) {
        error_log("process_data_update: 업데이트 WHERE 조건이 비어 있습니다. 전체 테이블 업데이트 방지.");
        return false;
    }

    $setParts = [];
    foreach (array_keys($data) as $col) {
        $setParts[] = "`" . str_replace("`", "``", $col) . "` = :" . $col;
    }
    $setSql = implode(', ', $setParts);

    $whereParts = [];
    $whereData = [];
    foreach ($whereConditions as $col => $value) {
        $placeholder = ":where_" . $col;
        $whereParts[] = "`" . str_replace("`", "``", $col) . "` = " . $placeholder;
        $whereData[$placeholder] = $value;
    }
    $whereSql = implode(' AND ', $whereParts);

    $sql = "UPDATE `" . str_replace("`", "``", $tableName) . "` SET {$setSql} WHERE {$whereSql}";

    $bindData = array_merge($data, $whereData);

    try {
        $stmt = $pdo->prepare($sql); // 전역 $pdo 사용
        $stmt->execute($bindData);
        return true;

    } catch (PDOException $e) {
        error_log("process_data_update 오류 ({$tableName}): " . $e->getMessage());
        return false;
    }
}

/**
 * 파일 메타데이터 업데이트 처리 함수 (process_file_update)
 * 데이터베이스에 기록된 파일 정보(이름, 연결 ID 등)를 업데이트할 때 사용합니다.
 * 실제 서버에 저장된 파일의 내용을 변경하거나 이동하는 기능이 아닙니다.
 * 전역 변수 $pdo 를 사용합니다.
 *
 * @param string $tableName 파일 정보를 업데이트할 테이블 이름 (예: 'cm_board_file')
 * @param array $data 업데이트할 파일 데이터 (컬럼명 => 값 형태의 연관 배열)
 * @param array $whereConditions WHERE 절 조건 (컬럼명 => 값 형태의 연관 배열)
 * @return bool 성공 시 true, 실패 시 false 반환
 */
function process_file_update(string $tableName, array $data, array $whereConditions)
{
     global $pdo; // <-- 여기서 전역 변수 $pdo 에 접근!
     // 내부 로직은 process_data_update 와 동일하게 global $pdo 를 사용하도록 변경했습니다.

     if (empty($data)) {
        error_log("process_file_update: 업데이트할 데이터가 비어 있습니다.");
        return false;
    }
    if (empty($whereConditions)) {
        error_log("process_file_update: 업데이트 WHERE 조건이 비어 있습니다. 전체 테이블 업데이트 방지.");
        return false;
    }

    $setParts = [];
    foreach (array_keys($data) as $col) {
        $setParts[] = "`" . str_replace("`", "``", $col) . "` = :" . $col;
    }
    $setSql = implode(', ', $setParts);

    $whereParts = [];
    $whereData = [];
    foreach ($whereConditions as $col => $value) {
        $placeholder = ":where_" . $col;
        $whereParts[] = "`" . str_replace("`", "``", $col) . "` = " . $placeholder;
        $whereData[$placeholder] = $value;
    }
    $whereSql = implode(' AND ', $whereParts);

    $sql = "UPDATE `" . str_replace("`", "``", $tableName) . "` SET {$setSql} WHERE {$whereSql}";

    $bindData = array_merge($data, $whereData);

    try {
        $stmt = $pdo->prepare($sql); // 전역 $pdo 사용
        $stmt->execute($bindData);
        return true;

    } catch (PDOException $e) {
        error_log("process_file_update 오류 ({$tableName}): " . $e->getMessage());
        return false;
    }
}


/**
 * 데이터 삭제 처리 함수 (process_data_delete)
 * 어떤 테이블에서든 데이터를 삭제할 때 사용할 수 있습니다.
 * 삭제 조건은 $whereConditions 배열에 담아주세요.
 * 전역 변수 $pdo 를 사용합니다.
 *
 * @param string $tableName 데이터를 삭제할 테이블 이름
 * @param array $whereConditions WHERE 절 조건 (컬럼명 => 값 형태의 연관 배열)
 * @return bool 성공 시 true, 실패 시 false 반환
 */
function process_data_delete(string $tableName, array $whereConditions)
{
     global $pdo; // <-- 여기서 전역 변수 $pdo 에 접근!

    if (empty($whereConditions)) {
        error_log("process_data_delete: 삭제 WHERE 조건이 비어 있습니다. 전체 테이블 삭제 방지.");
        return false;
    }

    $whereParts = [];
    $whereData = [];
    foreach ($whereConditions as $col => $value) {
        $placeholder = ":where_" . $col;
        $whereParts[] = "`" . str_replace("`", "``", $col) . "` = " . $placeholder;
        $whereData[$placeholder] = $value;
    }
    $whereSql = implode(' AND ', $whereParts);

    $sql = "DELETE FROM `" . str_replace("`", "``", $tableName) . "` WHERE {$whereSql}";

    try {
        $stmt = $pdo->prepare($sql); // 전역 $pdo 사용
        $stmt->execute($whereData);
        return true;

    } catch (PDOException $e) {
        error_log("process_data_delete 오류 ({$tableName}): " . $e->getMessage());
        return false;
    }
}

/**
 * 파일 메타데이터 삭제 처리 함수 (process_file_delete)
 * 데이터베이스에 기록된 파일 정보만 삭제합니다.
 * 이 함수를 호출하기 전에 또는 호출한 후에 실제 서버에 저장된 파일은 별도로 삭제하는 로직이 필요합니다.
 * 전역 변수 $pdo 를 사용합니다.
 *
 * @param string $tableName 파일 정보를 삭제할 테이블 이름 (예: 'cm_board_file')
 * @param array $whereConditions WHERE 절 조건 (컬럼명 => 값 형태의 연관 배열)
 * @return bool 성공 시 true, 실패 시 false 반환
 */
function process_file_delete(string $tableName, array $whereConditions)
{
    global $pdo; // <-- 여기서 전역 변수 $pdo 에 접근!
    // 내부 로직은 process_data_delete 와 동일하게 global $pdo 를 사용하도록 변경했습니다.
    // 중요한 점: 이 함수는 DB에서 파일 *정보*만 삭제합니다. 실제 서버에 저장된 파일(예: uploads 폴더의 파일)은 이 함수와 별개로 직접 삭제해야 합니다!

    if (empty($whereConditions)) {
        error_log("process_file_delete: 삭제 WHERE 조건이 비어 있습니다. 전체 테이블 삭제 방지.");
        return false;
    }

    $whereParts = [];
    $whereData = [];
    foreach ($whereConditions as $col => $value) {
        $placeholder = ":where_" . $col;
        $whereParts[] = "`" . str_replace("`", "``", $col) . "` = " . $placeholder;
        $whereData[$placeholder] = $value;
    }
    $whereSql = implode(' AND ', $whereParts);

    $sql = "DELETE FROM `" . str_replace("`", "``", $tableName) . "` WHERE {$whereSql}";

    try {
        $stmt = $pdo->prepare($sql); // 전역 $pdo 사용
        $stmt->execute($whereData);
        return true;

    } catch (PDOException $e) {
        error_log("process_file_delete 오류 ({$tableName}): " . $e->getMessage());
        return false;
    }
}


// 이 함수는 별도의 파일 (예: summernote_upload.php) 에 포함될 것입니다.
// CM_DATA_PATH 와 CM_DATA_URL 상수가 정의되어 있어야 합니다.
// CM_DATA_PATH: 서버 파일 시스템 경로 (예: /var/www/html/data)
// CM_DATA_URL: 웹에서 접근 가능한 URL 경로 (예: http://yourdomain.com/data)
// 물론 $board 값도 함수 호출 시 넘겨받거나, 이 파일 상단에서 정의되어 있어야 합니다.

/**
 * Summernote 에디터에서 업로드된 이미지를 처리하고 저장 경로를 반환하는 함수
 *
 * @param array $fileInfo $_FILES 배열에서 해당 이미지 파일 하나의 정보
 *                        (예: $_FILES['summernote_image'] 또는 $_FILES['files']['name'][0] 등의 단일 파일 정보 구조)
 * @param string $board 현재 게시판 종류 (저장 디렉토리 경로 생성에 사용)
 * @return string|false 성공 시 웹 접근 가능 이미지 URL, 실패 시 false 반환
 */
function process_summernote_image_upload(array $fileInfo, string $board)
{
    // 업로드 오류 확인
    if (!isset($fileInfo['error']) || $fileInfo['error'] !== UPLOAD_ERR_OK) {
        error_log("Summernote 이미지 업로드 오류: 코드 " . ($fileInfo['error'] ?? '알 수 없음'));
        return false; // 업로드 자체에 오류가 있음
    }

    // 파일 정보 추출
    $tmp_name = $fileInfo['tmp_name'];
    $original_filename = $fileInfo['name'];
    $file_size = $fileInfo['size'];
    $file_type = $fileInfo['type'];

    // 이미지 파일인지 기본적인 MIME 타입으로 확인 (보안을 위해 더 정밀한 검사 필요할 수 있습니다)
    // 실제 이미지인지 확인하는 추가적인 검사 로직을 여기에 넣는 것이 좋습니다.
    $allowed_types = ['image/jpeg', 'image/png', 'image/gif', 'image/webp'];
    if (!in_array($file_type, $allowed_types)) {
         error_log("Summernote 이미지 업로드 오류: 허용되지 않는 파일 타입 ({$file_type})");
         return false;
    }

    // 파일 확장자 추출
    $file_ext = strtolower(pathinfo($original_filename, PATHINFO_EXTENSION));

    // 저장할 디렉토리 경로 설정
    // CM_DATA_PATH는 서버의 물리적인 경로입니다. (예: /var/www/html/data)
    $upload_dir = CM_DATA_PATH . '/board/' . $board . '/editor/';

    // 업로드 디렉토리 생성 (없으면)
    if (!file_exists($upload_dir)) {
        // 0777 권한은 보안상 위험할 수 있으므로, 서버 환경에 맞는 적절한 권한 설정이 필요합니다.
        // 웹 서버(PHP 실행 유저)가 해당 디렉토리에 쓰기 권한이 있어야 합니다.
        if (!mkdir($upload_dir, 0777, true)) {
            error_log("Summernote 이미지 업로드 오류: 디렉토리 생성 실패 ({$upload_dir})");
            return false; // 디렉토리 생성 실패
        }
         // 생성된 디렉토리의 소유권/권한 조정 필요할 수 있습니다. (chown, chmod)
    }

    // 저장할 고유한 파일 이름 생성 (원본 파일 이름 사용은 위험)
    // 파일명 충돌 방지 및 보안 강화
    $stored_filename = uniqid() . '_' . bin2hex(random_bytes(8)) . '.' . $file_ext;

    // 파일 저장 경로 (서버 경로)
    $upload_file_path = $upload_dir . $stored_filename;

    // 임시 파일을 최종 저장 경로로 이동
    if (move_uploaded_file($tmp_name, $upload_file_path)) {
        // 파일 저장 성공 시, 웹에서 접근 가능한 URL 경로 생성
        // CM_DATA_URL는 웹 서버의 Document Root 기준으로 설정된 URL 경로입니다. (예: http://yourdomain.com/data)
        // 이 상수가 제대로 정의되어 있어야 합니다.
        if (!defined('CM_DATA_URL')) {
             error_log("Summernote 이미지 업로드 오류: CM_DATA_URL 상수가 정의되지 않았습니다.");
             // 업로드된 파일 삭제 (정리가 필요)
             if (file_exists($upload_file_path)) {
                 unlink($upload_file_path);
             }
             return false;
        }

        $web_accessible_url = CM_DATA_URL . '/board/' . $board . '/editor/' . $stored_filename;

        // 필요하다면 여기서 cm_board_file 테이블에 파일 정보를 기록할 수도 있습니다.
        // 이 경우 global $pdo; 를 사용하거나 $pdo 객체를 인자로 받아야 합니다.
        // 예:
        // global $pdo;
        // if ($pdo) {
        //     $fileMetaData = [
        //         'board' => $board,
        //         'board_id' => 0, // !!! 글쓰기 중에는 board_id를 아직 모르므로 0이나 임시값 사용 또는 나중에 업데이트
        //         'original_filename' => $original_filename,
        //         'stored_filename' => $stored_filename,
        //         'file_size' => $file_size,
        //         'file_type' => $file_type,
        //         'is_editor_image' => 1 // 에디터 이미지임을 표시하는 컬럼 추가 필요
        //     ];
        //     process_file_insert('cm_board_file', $fileMetaData); // $pdo는 global로 사용
        //     // 주의: 이 경우 board_id를 나중에 어떻게 업데이트할지 고민해야 합니다.
        //     // 또는 editor 이미지 DB 기록은 하지 않고 파일만 저장하는 것으로 단순화할 수 있습니다.
        // }


        return $web_accessible_url; // 성공 시 URL 반환

    } else {
        // 파일 이동 실패
        error_log("Summernote 이미지 업로드 오류: 파일 이동 실패 ({$tmp_name} to {$upload_file_path})");
        return false;
    }
}



