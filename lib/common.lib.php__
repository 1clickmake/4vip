$deleteFileByBoardConditions = [ 'board_id' => 99, ]; // 실제 DB에 board_id가 '99' 인 파일 정보가 있어야 함

// process_file_delete 함수 호출 (이제 $pdo 인자를 넘기지 않습니다)
$deleteFileSuccess = process_file_delete('cm_board_file', $deleteFileByBoardConditions);

if ($deleteFileSuccess) {
    echo "<p style='color: green;'>파일 메타데이터 삭제 성공! (해당 board_id의 파일 정보가 있었다면)</p>";
     // !!! 중요: 이 함수는 DB에서 파일 *정보*만 삭제합니다. 실제 서버에 저장된 파일(예: uploads 폴더의 파일)은
     // 이 함수와 별개로 직접 삭제하는 로직을 추가해야 합니다! 예를 들어, 삭제할 파일 목록을 먼저 조회한 후에
     // 파일 정보 삭제 함수를 호출하고, 그 후에 실제 파일들을 unlink() 등으로 삭제하는 방식이 필요합니다.
} else {
    echo "<p style='color: red;'>파일 메타데이터 삭제 실패 ㅠㅠ (board_id 99에 연결된 파일 정보가 없거나 오류 발생)</p>";
}

echo "<hr>";

// --- 샘플 끝 ---
*/

function sql_fetch(string $sql, array $params = []) // 두 번째 인자로 $params 배열을 추가했어요!
{
    global $pdo; // 데이터베이스 연결 객체인 $pdo에 접근

    if (!$pdo) {
        error_log("sql_fetch 오류: 데이터베이스 연결( \$pdo )이 설정되지 않았습니다.");
        return false;
    }

    try {
        // 쿼리 준비 - 쿼리 문자열 자체에는 사용자 입력 값이 들어가지 않아요!
        $stmt = $pdo->prepare($sql);

        // 쿼리 실행 및 파라미터 바인딩 - 여기서 $params 배열의 값들이 안전하게 바인딩됩니다.
        $executeResult = $stmt->execute($params);

        // execute() 메소드가 실패할 경우 false를 반환할 수 있으므로 확인합니다.
        if ($executeResult === false) {
             error_log("sql_fetch 오류: 쿼리 실행 실패. [쿼리: " . $sql . "] [파라미터: " . print_r($params, true) . "]");
             return false;
        }


        // 결과의 첫 번째 행을 연관 배열로 가져오기
        // 결과가 없으면 false를 반환합니다.
        $result = $stmt->fetch(PDO::FETCH_ASSOC);

        // Statement 객체 닫기 (선택 사항이지만 리소스 관리에 좋음)
        $stmt->closeCursor();

        return $result;

    } catch (PDOException $e) {
        // 데이터베이스 관련 오류 발생 시
        error_log("sql_fetch 오류: " . $e->getMessage() . " [쿼리: " . $sql . "] [파라미터: " . print_r($params, true) . "]");
        return false;
    } catch (Exception $e) {
        // 그 외 일반적인 오류 발생 시
         error_log("sql_fetch 알 수 없는 오류: " . $e->getMessage() . " [쿼리: " . $sql . "] [파라미터: " . print_r($params, true) . "]");
         return false;
    }
}

/*
// 검색 조건 값이라고 가정
$board_id_param = 'free_board';
$skin_param = 'basic';

// sql_fetch 함수를 사용하여 데이터 조회 (AND 조건)
// 쿼리에 플레이스홀더를 여러 개 사용
// 두 번째 인자 배열에 해당 플레이스홀더에 들어갈 값들을 순서대로 또는 이름에 맞게 넣기

// 1. 위치 기반 플레이스홀더 (?) 사용
$sql_and_pos = "SELECT * FROM `cm_board_list` WHERE `board_id` = ? AND `skin` = ?";
$params_and_pos = [$board_id_param, $skin_param]; // ? 순서대로 값을 배열에 넣어요

$boardInfo_and = sql_fetch($sql_and_pos, $params_and_pos);


// 2. 이름 기반 플레이스홀더 (:이름) 사용 (이게 더 추천드려요! 가독성이 좋아요)
$sql_and_named = "SELECT * FROM `cm_board_list` WHERE `board_id` = :board_id AND `skin` = :skin";
$params_and_named = [':board_id' => $board_id_param, ':skin' => $skin_param]; // ':이름' => 값 형태로 넣어요

// $boardInfo_and = sql_fetch($sql_and_named, $params_and_named); // 위 쿼리 대신 이걸 써도 결과는 같아요

// 결과 확인 및 사용
if ($boardInfo_and !== false && $boardInfo_and) {
    echo "AND 조건 검색 결과:<br>";
    echo "게시판 이름: " . $boardInfo_and['board_name'];
    echo "<br>";
    echo "스킨: " . $boardInfo_and['skin'];
} else {
    echo "AND 조건에 맞는 게시판 정보를 찾을 수 없습니다.";
}

// 검색 조건 값이라고 가정
$board_id_1 = 'notice';
$board_id_2 = 'faq';

